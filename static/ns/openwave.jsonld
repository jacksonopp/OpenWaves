{
  "@context": {
    "ow": "https://example.com/ns/openwave#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "stationUri": {
      "@id": "ow:stationUri",
      "@type": "@id"
    },
    "isLive": {
      "@id": "ow:isLive",
      "@type": "xsd:boolean"
    },
    "hlsManifest": {
      "@id": "ow:hlsManifest",
      "@type": "@id"
    },
    "streamExpiry": {
      "@id": "ow:streamExpiry",
      "@type": "xsd:dateTime"
    },
    "broadcastStatus": {
      "@id": "ow:broadcastStatus",
      "@comment": "Values: offline | live | scheduled"
    },
    "audioCodec": {
      "@id": "ow:audioCodec"
    },
    "bitrate": {
      "@id": "ow:bitrate",
      "@type": "xsd:integer"
    },
    "relayPolicy": {
      "@id": "ow:relayPolicy",
      "@comment": "Values: open | allowlist | closed"
    },
    "licenseTerritory": {
      "@id": "ow:licenseTerritory",
      "@container": "@set",
      "@comment": "ISO 3166-1 alpha-2 country codes; [\"*\"] means worldwide"
    }
  }
}
