{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Server (dev)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/server",
      "output": "${workspaceFolder}/bin/server",
      "cwd": "${workspaceFolder}",
      "buildFlags": "-tags admindev",
      "env": {
        "ADMINUI_DEV_PROXY": "http://localhost:5173"
      }
    },
    {
      "name": "Run Server (prod)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/server",
      "output": "${workspaceFolder}/bin/server",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Build UI"
    }
  ]
}
